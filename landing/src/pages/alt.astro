---
// Alternative landing — "Precision / Technical" direction.
// Menlo mono identity + teal-blue accent, light. Hairline borders, soft
// shadows, calm motion, line icons, a detector-style locator (not a claw).
// Self-contained, served at /alt so the primary landing stays untouched.

const GH = "https://github.com/AppiumTestDistribution/appclaw";
const QUICKSTART = `${GH}#quick-start`;
const MARKETPLACE =
  "https://marketplace.visualstudio.com/items?itemName=AppClaw.appclaw";

const PROVIDERS = ["Anthropic", "OpenAI", "Google", "Groq", "Ollama"];

// "Say it. It does it." — plain English → underlying action
const CAPS = [
  { say: "open WhatsApp", act: "launch" },
  { say: "tap the search icon", act: "tap" },
  { say: 'type "Appium 3.0"', act: "type" },
  { say: "scroll until Pricing is visible", act: "scroll" },
  { say: "swipe to the next photo", act: "swipe" },
  { say: "verify the cart shows 2 items", act: "assert" },
  { say: "wait for the spinner to finish", act: "wait" },
  { say: "tap Login below the password", act: "locate" },
];

const MODES = [
  {
    tag: "agent", title: "From prompt to done",
    desc: "Describe a goal in plain English. AppClaw reads the screen, reasons, and executes until it's finished.",
    lines: [["$", "appclaw ", "\"Turn on WiFi\""], ["1/3", "launch", "→ Settings"], ["2/3", "tap", "→ Network"], ["3/3", "tap", "→ Wi-Fi"], ["✓", "Done", "— 8s · $0.002"]],
  },
  {
    tag: "yaml", title: "Deterministic, $0 at runtime",
    desc: "Write plain-English YAML. No AI needed when you run it — fast, repeatable, with vision fallback.",
    lines: [["steps:", "", ""], ["-", "open YouTube", ""], ["-", "tap search", ""], ["-", "type \"Appium\"", ""], ["done:", "\"results up\"", ""]],
  },
  {
    tag: "playground", title: "Build flows live",
    desc: "A REPL on a real device. Type commands, watch them run, export straight to YAML.",
    lines: [["pg>", "tap Settings", ""], ["✓", "Tapped it", ""], ["pg>", "scroll General", ""], ["✓", "Visible", ""], ["pg>", "/export y.yaml", ""]],
  },
];

const STEPS = [
  { n: "01", t: "Describe your goal", d: "Plain English as a prompt, a YAML file, or a playground command. No selectors." },
  { n: "02", t: "It perceives & reasons", d: "AppClaw reads the screen, sends it to your LLM, and gets back a structured plan. Adapts to popups." },
  { n: "03", t: "Execute & verify", d: "Actions run through Appium via MCP. It checks after every step until the goal is met." },
];

const APPS = ["Gmail", "YouTube", "WhatsApp", "Chrome", "Settings"];

// device rack — many small tiles, deterministic mix of states
const RACK = Array.from({ length: 24 }, (_, i) => {
  const r = (i * 7 + 5) % 11;
  const s = r === 0 ? "idle" : r > 8 ? "pass" : "run";
  const w = s === "pass" ? 100 : s === "idle" ? 0 : 22 + ((i * 41) % 70);
  return { s, w };
});
const rackRunning = RACK.filter((d) => d.s === "run").length;
const rackPassed = RACK.filter((d) => d.s === "pass").length;
const rackQueued = RACK.filter((d) => d.s === "idle").length;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AppClaw — the mobile automation agent</title>
    <meta name="description" content="The mobile automation agent. Say what you want in plain English — AppClaw locates the right element and taps, types, and swipes across real Android and iOS devices." />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300..700&family=JetBrains+Mono:ital,wght@0,400..700;1,400..600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --paper: #fbfbf9;
        --paper-2: #f4f4f0;
        --card: #ffffff;
        --ink: #14161b;
        --ink-soft: #5b606a;
        --ink-faint: #9499a2;
        --accent: #0fa3b4;        /* teal blue */
        --accent-bright: #2ec7d8; /* for dark code surfaces */
        --accent-deep: #0b7c8b;   /* readable teal on paper */
        --accent-soft: #e6f4f6;
        --line: #e7e7e1;
        --line-2: #d8d8d2;
        --code: #0e1116;
        --r: 10px;
        --ease: cubic-bezier(0.16, 1, 0.3, 1);
        --font-display: "Menlo", "SF Mono", "JetBrains Mono", ui-monospace, monospace;
        --font-body: "Geist", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --font-mono: "JetBrains Mono", "SF Mono", Menlo, monospace;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--font-body);
        background: var(--paper);
        color: var(--ink);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      ::selection { background: var(--accent-soft); color: var(--accent-deep); }
      a { color: inherit; text-decoration: none; }
      .wrap { max-width: 1120px; margin: 0 auto; padding: 0 28px; }

      h1, h2, h3, .mono { font-family: var(--font-display); }
      h1, h2, h3 { font-weight: 600; letter-spacing: -0.02em; line-height: 1.04; }

      /* reveal */
      .rv { opacity: 0; transform: translateY(16px); }
      .rv.in { opacity: 1; transform: none; transition: opacity 0.6s var(--ease), transform 0.7s var(--ease); }
      .d1 { transition-delay: 0.07s; } .d2 { transition-delay: 0.14s; } .d3 { transition-delay: 0.21s; }
      @media (prefers-reduced-motion: reduce) { .rv { opacity: 1; transform: none; } }

      /* eyebrow */
      .eyebrow { display: inline-flex; align-items: center; gap: 9px; font-family: var(--font-mono); font-size: 11.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.16em; color: var(--accent-deep); }
      .eyebrow::before { content: ""; width: 18px; height: 1px; background: var(--accent); }

      /* buttons */
      .btn { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-body); font-weight: 600; font-size: 14.5px; padding: 11px 20px; border-radius: 8px; border: 1px solid var(--accent-deep); background: var(--accent-deep); color: #fff; cursor: pointer; transition: background 0.18s, transform 0.18s var(--ease), box-shadow 0.18s; }
      .btn:hover { background: #096572; transform: translateY(-1px); box-shadow: 0 8px 22px -10px rgba(11,124,139,0.7); }
      .btn.alt { background: var(--card); color: var(--ink); border-color: var(--line-2); }
      .btn.alt:hover { background: var(--paper-2); border-color: var(--ink-faint); box-shadow: none; }
      .btn.sm { font-size: 13px; padding: 8px 15px; }

      /* card */
      .card { border: 1px solid var(--line); border-radius: var(--r); background: var(--card); }
      .card.soft { box-shadow: 0 1px 2px rgba(20,22,27,0.04), 0 14px 34px -22px rgba(20,22,27,0.22); }
      .card.hover { transition: border-color 0.2s, transform 0.2s var(--ease), box-shadow 0.2s; }
      .card.hover:hover { border-color: var(--line-2); transform: translateY(-2px); box-shadow: 0 1px 2px rgba(20,22,27,0.04), 0 18px 40px -24px rgba(20,22,27,0.28); }

      .pill { display: inline-flex; align-items: center; gap: 7px; font-size: 13px; color: var(--ink-soft); border: 1px solid var(--line); border-radius: 7px; padding: 6px 12px; background: var(--card); }
      .pill .dot { width: 5px; height: 5px; border-radius: 50%; background: var(--accent); }
      .mono-tag { font-family: var(--font-mono); font-size: 11px; color: var(--ink-faint); border: 1px solid var(--line); border-radius: 5px; padding: 2px 7px; }

      /* NAV */
      nav { position: sticky; top: 0; z-index: 100; border-bottom: 1px solid transparent; background: rgba(251,251,249,0.8); backdrop-filter: blur(12px); transition: border-color 0.25s; }
      nav.scrolled { border-bottom-color: var(--line); }
      .nav-bar { display: flex; align-items: center; gap: 22px; height: 60px; }
      .brand { display: flex; align-items: center; gap: 9px; font-family: var(--font-display); font-weight: 600; font-size: 17px; letter-spacing: -0.02em; }
      .brand img { width: 22px; height: 22px; }
      .nav-links { display: flex; gap: 2px; margin-left: auto; }
      .nav-links a { font-size: 14px; color: var(--ink-soft); padding: 7px 12px; border-radius: 7px; transition: color 0.15s, background 0.15s; }
      .nav-links a:hover { color: var(--ink); background: var(--paper-2); }
      .nav-cta { display: flex; align-items: center; gap: 8px; }

      /* HERO */
      .hero { padding: 64px 0 56px; position: relative; overflow: hidden; }
      .hero::before { content: ""; position: absolute; inset: 0; z-index: -1; background-image: linear-gradient(var(--line) 1px, transparent 1px), linear-gradient(90deg, var(--line) 1px, transparent 1px); background-size: 60px 60px; opacity: 0.5; -webkit-mask-image: radial-gradient(ellipse 70% 60% at 60% 35%, #000 10%, transparent 75%); mask-image: radial-gradient(ellipse 70% 60% at 60% 35%, #000 10%, transparent 75%); }
      .hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 56px; align-items: center; }
      .hero h1 { font-size: clamp(38px, 5.2vw, 62px); margin-top: 22px; }
      .hero h1 .ac { color: var(--accent-deep); }
      .hero-sub { font-size: 18px; color: var(--ink-soft); max-width: 500px; margin: 22px 0 26px; }
      .hero-sub a { color: var(--ink); font-weight: 500; border-bottom: 1px solid var(--accent); }
      .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; }
      .hero-meta { display: flex; flex-wrap: wrap; gap: 8px 16px; margin-top: 22px; font-family: var(--font-mono); font-size: 12px; color: var(--ink-faint); }
      .hero-meta span { display: inline-flex; align-items: center; gap: 7px; }
      .hero-meta i { width: 4px; height: 4px; border-radius: 50%; background: var(--accent); display: inline-block; }

      /* PHONE + locator */
      .stage { position: relative; width: 286px; max-width: 100%; margin: 0 auto; }
      .device { position: relative; width: 286px; aspect-ratio: 286 / 580; background: #0c0e12; border-radius: 42px; padding: 8px; box-shadow: 0 2px 4px rgba(20,22,27,0.06), 0 40px 80px -30px rgba(20,22,27,0.4); border: 1px solid #000; }
      .screen { width: 100%; height: 100%; background: var(--card); border-radius: 35px; overflow: hidden; display: flex; flex-direction: column; }
      .statusbar { display: flex; justify-content: space-between; align-items: center; padding: 14px 22px 8px; font-family: var(--font-mono); font-size: 11px; font-weight: 600; }
      .sig { display: flex; align-items: flex-end; gap: 2px; }
      .sig i { display: block; width: 3px; background: var(--ink); border-radius: 1px; }
      .sig i:nth-child(1){height:4px}.sig i:nth-child(2){height:6px}.sig i:nth-child(3){height:8px}.sig i:nth-child(4){height:10px}
      .batt { width: 20px; height: 11px; border: 1.4px solid var(--ink); border-radius: 3px; position: relative; margin-left: 5px; }
      .batt::before { content:""; position:absolute; right:-3px; top:3px; width:2px; height:5px; background:var(--ink); border-radius:0 2px 2px 0; }
      .batt::after { content:""; position:absolute; inset:2px; width:62%; background:var(--accent); border-radius:1px; }
      .appbar { display: flex; justify-content: space-between; align-items: center; padding: 10px 22px 14px; border-bottom: 1px solid var(--line); }
      .appbar .app { font-family: var(--font-display); font-weight: 600; font-size: 15px; }
      .appbar .lnk { font-family: var(--font-mono); font-size: 11px; color: var(--ink-faint); }
      .scr-body { padding: 22px 22px; display: flex; flex-direction: column; gap: 13px; flex: 1; }
      .scr-body h5 { font-size: 18px; font-weight: 600; }
      .field { height: 42px; border: 1px solid var(--line-2); border-radius: 9px; display: flex; align-items: center; padding: 0 13px; font-family: var(--font-mono); font-size: 12px; color: var(--ink-faint); }
      .loginbtn { position: relative; margin-top: 6px; height: 46px; border-radius: 9px; background: var(--accent-deep); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px; }
      .reticle { position: absolute; inset: -9px; border: 1.5px solid var(--accent); border-radius: 13px; pointer-events: none; }
      .reticle::before, .reticle::after { content: ""; position: absolute; width: 7px; height: 7px; background: var(--accent); border-radius: 1px; }
      .reticle::before { top: -4px; left: -4px; } .reticle::after { bottom: -4px; right: -4px; }
      .rlabel { position: absolute; top: -10px; right: -8px; transform: translateY(-100%); font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.04em; color: #fff; background: var(--accent-deep); padding: 3px 8px; border-radius: 6px; white-space: nowrap; }
      .signup { text-align: center; font-family: var(--font-mono); font-size: 11px; color: var(--ink-faint); }
      .signup .dlink { color: var(--ink-soft); border-bottom: 1px solid var(--line-2); }
      .stage-cap { text-align: center; margin-top: 18px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; color: var(--ink-faint); }
      .stage-cap b { color: var(--accent-deep); font-weight: 600; }

      /* logos row */
      .providers { display: flex; flex-wrap: wrap; align-items: center; gap: 10px 26px; }
      .providers .lbl { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-faint); }
      .providers .p { font-family: var(--font-display); font-weight: 600; font-size: 15px; color: var(--ink-soft); }

      /* context + memory */
      .ctx-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
      .feat { padding: 26px; display: flex; flex-direction: column; }
      .feat .fh { display: flex; align-items: center; gap: 13px; }
      .feat .fic { width: 44px; height: 44px; border: 1px solid #cde9ec; border-radius: 11px; display: grid; place-items: center; color: var(--accent-deep); background: var(--accent-soft); flex-shrink: 0; }
      .feat .fk { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-faint); }
      .feat h3 { font-size: 19px; letter-spacing: -0.01em; margin-top: 2px; }
      .feat p { color: var(--ink-soft); font-size: 14.5px; line-height: 1.55; margin-top: 14px; }
      .feat .chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }
      .feat .path { margin-top: auto; padding-top: 16px; font-family: var(--font-mono); font-size: 12px; color: var(--accent-deep); }
      .mini { margin-top: 16px; border: 1px solid var(--line); border-radius: 9px; overflow: hidden; }
      .mini .r { display: grid; grid-template-columns: 50px 1fr auto; gap: 12px; align-items: center; padding: 11px 13px; font-family: var(--font-mono); font-size: 12px; color: var(--ink-soft); }
      .mini .r + .r { border-top: 1px solid var(--line); }
      .mini .r.now { background: var(--accent-soft); }
      .mini .tag { color: var(--ink-faint); }
      .mini .good { color: var(--accent-deep); font-weight: 600; }

      /* SECTION */
      section.block { padding: 70px 0; }
      /* full-bleed tinted band — alternating sections read as distinct blocks */
      .block.band {
        margin-inline: calc(50% - 50vw);
        padding-inline: calc(50vw - 50%);
        background: var(--paper-2);
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }
      .sec-head { max-width: 640px; margin-bottom: 40px; }
      .sec-head h2 { font-size: clamp(28px, 3.6vw, 44px); margin-top: 16px; }
      .sec-head h2 .ac { color: var(--accent-deep); }
      .sec-head p { font-size: 17px; color: var(--ink-soft); margin-top: 14px; }

      /* SAY IT */
      .say-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 48px; align-items: center; }
      .say-list { overflow: hidden; }
      .say-row { display: flex; align-items: center; gap: 13px; padding: 13px 18px; border-bottom: 1px solid var(--line); }
      .say-row:last-child { border-bottom: none; }
      .say-row .ck { color: var(--accent); flex-shrink: 0; display: grid; place-items: center; }
      .say-row .txt { flex: 1; font-family: var(--font-mono); font-size: 13px; color: var(--ink); }
      .say-row .act { font-family: var(--font-mono); font-size: 11px; color: var(--ink-faint); border: 1px solid var(--line); border-radius: 5px; padding: 2px 8px; }

      /* modes */
      .modes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
      .mode { padding: 24px; display: flex; flex-direction: column; }
      .mode-tag { align-self: flex-start; font-family: var(--font-mono); font-size: 11px; font-weight: 600; letter-spacing: 0.04em; color: var(--accent-deep); background: var(--accent-soft); border: 1px solid #cde9ec; padding: 3px 9px; border-radius: 6px; margin-bottom: 16px; }
      .mode h3 { font-size: 19px; margin-bottom: 8px; letter-spacing: -0.01em; }
      .mode p { color: var(--ink-soft); font-size: 14.5px; margin-bottom: 18px; flex: 1; line-height: 1.55; }
      .screen-blk { border: 1px solid var(--line); border-radius: 9px; background: var(--paper-2); color: var(--ink-soft); font-family: var(--font-mono); font-size: 12px; line-height: 1.85; padding: 13px 14px; overflow-x: auto; }
      .screen-blk .o { color: var(--accent-deep); font-weight: 600; } .screen-blk .m { color: var(--ink-faint); }

      /* proximity */
      .prox-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
      .prox-tags { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 22px; }
      .prox-stage { padding: 34px 26px; display: flex; flex-direction: column; gap: 11px; align-items: center; background: var(--paper-2); }
      .uic { width: 100%; max-width: 244px; text-align: center; font-family: var(--font-mono); font-size: 13px; padding: 13px; border: 1px solid var(--line-2); border-radius: 9px; background: var(--card); }
      .uic.decoy { color: var(--ink-faint); }
      .uic.anchor { border-style: dashed; border-color: var(--accent); color: var(--accent-deep); position: relative; }
      .uic.anchor .lab { position: absolute; right: -12px; top: 50%; transform: translateY(-50%) translateX(100%); font-size: 10px; letter-spacing: 0.06em; color: var(--accent-deep); }
      .rel { display: flex; align-items: center; gap: 7px; font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.06em; color: var(--accent-deep); }
      .uic.target { border: 1.5px solid var(--accent); background: var(--accent-soft); color: var(--accent-deep); font-weight: 600; box-shadow: 0 0 0 4px rgba(15,163,180,0.1); }
      .prox-cmd { margin-top: 14px; width: 100%; max-width: 320px; font-family: var(--font-mono); font-size: 12.5px; padding: 12px 14px; border: 1px solid #1c2128; border-radius: 8px; background: var(--code); color: #c4ccd4; text-align: center; }
      .prox-cmd .g { color: var(--accent-bright); } .prox-cmd .o { color: #9fb4bd; }

      /* dual perception */
      .dp-grid { display: grid; grid-template-columns: 1fr auto 1fr; gap: 26px; align-items: stretch; }
      .dp-col { display: flex; flex-direction: column; }
      .dp-l { font-family: var(--font-mono); font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-faint); }
      .dp-l.ac { color: var(--accent-deep); }
      .dp-col h3 { font-size: 20px; margin-top: 6px; letter-spacing: -0.01em; }
      .dp-col .ds { font-size: 13.5px; color: var(--ink-soft); margin-top: 3px; }
      .dp-panel { margin-top: 16px; flex: 1; }
      .dp-foot { font-family: var(--font-mono); font-size: 11px; font-style: italic; color: var(--ink-faint); margin-top: 12px; }
      .dp-mid { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; min-width: 110px; }
      .dp-mid .vl { width: 1px; flex: 1; min-height: 26px; background: linear-gradient(var(--line-2), transparent); }
      .dp-mid .vl.b { background: linear-gradient(transparent, var(--line-2)); }
      .dp-pill { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; background: var(--accent-deep); color: #fff; padding: 9px 15px; border-radius: 100px; white-space: nowrap; box-shadow: 0 6px 18px -8px rgba(11,124,139,0.6); }
      .dp-strip { text-align: center; margin-top: 22px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-faint); }
      .dp-strip b { color: var(--accent-deep); }
      .domx { border: 1px solid var(--line); border-radius: 9px; background: var(--paper-2); color: var(--ink-soft); font-family: var(--font-mono); font-size: 12px; line-height: 1.9; padding: 14px 15px; overflow-x: auto; }
      .domx .file { color: var(--ink-faint); margin-bottom: 6px; }
      .domx .b { color: #2f6df0; } .domx .s { color: #1f8a5b; }
      .domx .matched { color: var(--accent-deep); background: var(--accent-soft); border-radius: 4px; padding: 0 4px; font-weight: 600; }
      .vmock { border: 1px solid var(--line); border-radius: 9px; background: var(--card); overflow: hidden; }
      .vmock .vh { display: flex; align-items: center; gap: 7px; padding: 9px 12px; font-family: var(--font-mono); font-size: 11px; color: var(--ink-faint); border-bottom: 1px solid var(--line); }
      .vmock .vb { padding: 14px; display: flex; flex-direction: column; gap: 9px; }
      .vmock .vbar { height: 9px; border-radius: 4px; background: var(--line-2); }
      .vmock .vbtn { position: relative; height: 38px; border-radius: 8px; border: 1.5px solid var(--accent); background: var(--accent-soft); display: grid; place-items: center; color: var(--accent-deep); font-size: 12.5px; font-weight: 600; }
      .vmock .vret { position: absolute; right: -8px; top: -8px; width: 19px; height: 19px; border: 1.5px solid var(--accent); border-radius: 50%; display: grid; place-items: center; font-size: 9px; color: var(--accent-deep); background: var(--card); }
      .vmock .vmatch { font-family: var(--font-mono); font-size: 10px; color: var(--accent-deep); text-align: right; }

      /* parallel — device rack */
      .rack-head { display: flex; align-items: center; gap: 18px; margin-bottom: 18px; font-family: var(--font-mono); font-size: 11px; color: var(--ink-faint); flex-wrap: wrap; }
      .rack-head .n { color: var(--ink); }
      .rack-head .lg { display: inline-flex; align-items: center; gap: 7px; }
      .rack-head .lg i { width: 7px; height: 7px; border-radius: 50%; display: inline-block; }
      .rack { display: grid; grid-template-columns: repeat(auto-fill, minmax(52px, 1fr)); gap: 9px; }
      .rack-card { background: var(--paper-2); padding: 18px; }
      .dev { aspect-ratio: 1 / 1.7; border: 1px solid var(--line-2); border-radius: 9px; background: var(--card); padding: 4px; position: relative; box-shadow: 0 1px 2px rgba(20,22,27,0.04), 0 8px 18px -16px rgba(20,22,27,0.28); transition: transform 0.16s var(--ease); }
      .dev:hover { transform: translateY(-2px); }
      .dev .scr { width: 100%; height: 100%; border-radius: 5px; background: var(--paper-2); display: flex; flex-direction: column; gap: 3px; padding: 6px 5px; }
      .dev .ln { height: 3px; border-radius: 2px; background: var(--line-2); }
      .dev .ln.t { background: var(--accent); }
      .dev .st { position: absolute; top: 6px; right: 6px; width: 5px; height: 5px; border-radius: 50%; }
      .dev .st.run { background: var(--accent); animation: pulse 1.8s ease-out infinite; }
      .dev .st.pass { background: #1f9d57; }
      .dev .st.idle { background: var(--ink-faint); opacity: 0.45; }
      @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(15,163,180,0.5); } 70% { box-shadow: 0 0 0 5px rgba(15,163,180,0); } 100% { box-shadow: 0 0 0 0 rgba(15,163,180,0); } }

      /* appguide */
      .ag-grid { display: grid; grid-template-columns: 1fr 1.05fr; gap: 48px; align-items: start; }
      .ag-apps { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 22px; }
      .ag-head { display: flex; align-items: center; gap: 8px; padding: 12px 18px; border-bottom: 1px solid var(--line); font-family: var(--font-mono); font-size: 12px; }
      .ag-head .k { color: var(--accent-deep); font-weight: 600; }
      .ag-head .v { color: var(--ink-faint); }
      .ag-body { padding: 18px 20px; font-family: var(--font-mono); font-size: 12.5px; line-height: 2; color: var(--ink-soft); }
      .ag-body b { color: var(--accent-deep); font-weight: 600; }

      /* steps */
      .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
      .step { padding: 26px; }
      .step .n { font-family: var(--font-mono); font-size: 13px; font-weight: 600; color: var(--accent-deep); padding-bottom: 14px; border-bottom: 1px solid var(--line); margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
      .step .n::after { content: ""; flex: 1; height: 1px; background: var(--line); }
      .step h3 { font-size: 18px; margin-bottom: 8px; letter-spacing: -0.01em; }
      .step p { color: var(--ink-soft); font-size: 14.5px; line-height: 1.55; }

      /* architecture */
      .arch2 { display: grid; grid-template-columns: 1fr auto 1.05fr; align-items: center; gap: 0; }
      .brain { padding: 26px 24px; }
      .brain .tt { display: flex; align-items: center; gap: 12px; }
      .brain .ic { width: 42px; height: 42px; border: 1px solid var(--line-2); border-radius: 10px; display: grid; place-items: center; color: var(--accent-deep); background: var(--accent-soft); flex-shrink: 0; }
      .brain h4 { font-family: var(--font-display); font-weight: 600; font-size: 20px; }
      .brain .sub { font-family: var(--font-mono); font-size: 11px; color: var(--ink-faint); letter-spacing: 0.04em; }
      .brain p { color: var(--ink-soft); font-size: 14px; margin-top: 12px; line-height: 1.55; }
      .loop { display: flex; align-items: center; gap: 7px; margin-top: 16px; flex-wrap: wrap; }
      .loop .lp { font-family: var(--font-mono); font-size: 12px; padding: 5px 11px; border: 1px solid var(--line-2); border-radius: 6px; }
      .loop .ar { color: var(--ink-faint); }
      .loop .re { font-family: var(--font-mono); font-size: 11px; color: var(--accent-deep); margin-left: 2px; }

      .wire { display: flex; flex-direction: column; align-items: center; gap: 9px; padding: 0 18px; }
      .wire .cable { display: flex; align-items: center; width: calc(100% + 48px); margin: 0 -24px; }
      .wire .cable .ln { flex: 1; height: 1px; background: var(--line-2); }
      .wire .plug { font-family: var(--font-mono); font-size: 12px; font-weight: 600; letter-spacing: 0.06em; padding: 7px 13px; margin: 0 8px; border: 1px solid var(--line-2); border-radius: 7px; background: var(--card); color: var(--accent-deep); }
      .wire .head { color: var(--ink-faint); }
      .wire .down { display: none; color: var(--ink-faint); font-size: 22px; }
      .wire .sub2 { font-family: var(--font-mono); font-size: 10px; color: var(--ink-faint); letter-spacing: 0.06em; text-align: center; max-width: 140px; line-height: 1.5; }

      .devland { position: relative; border: 1px dashed var(--line-2); border-radius: var(--r); background: var(--paper-2); padding: 22px 18px 18px; }
      .devland .lbl { position: absolute; top: -9px; left: 18px; background: var(--paper); color: var(--ink-faint); font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; padding: 2px 9px; border: 1px solid var(--line); border-radius: 5px; }
      .devland .note { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-faint); text-align: center; margin-bottom: 14px; }
      .dl-node { display: flex; align-items: center; gap: 12px; border: 1px solid var(--line); border-radius: 9px; background: var(--card); padding: 11px 13px; }
      .dl-node .di { width: 34px; height: 34px; border: 1px solid var(--line-2); border-radius: 8px; display: grid; place-items: center; color: var(--ink-soft); flex-shrink: 0; }
      .dl-node h5 { font-family: var(--font-display); font-weight: 600; font-size: 14px; }
      .dl-node small { font-family: var(--font-mono); font-size: 11px; color: var(--ink-faint); }
      .dl-conn { width: 1px; height: 14px; background: var(--line-2); margin: 0 auto; }

      .ico { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
      .ico.lg { width: 22px; height: 22px; }

      /* quote */
      .quote { max-width: 800px; margin: 0 auto; text-align: center; }
      .quote .q { font-family: var(--font-display); font-weight: 500; font-size: clamp(22px, 3vw, 32px); line-height: 1.35; letter-spacing: -0.01em; }
      .quote .q em { font-style: normal; color: var(--accent-deep); }
      .quote .by { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.06em; color: var(--ink-faint); margin-top: 22px; }

      /* CTA */
      .cta { border: 1px solid var(--line); border-radius: 16px; background: var(--code); color: #e7ecf1; padding: 56px 32px; text-align: center; position: relative; overflow: hidden; }
      .cta::before { content: ""; position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 44px 44px; -webkit-mask-image: radial-gradient(ellipse 60% 70% at 50% 0%, #000, transparent 70%); mask-image: radial-gradient(ellipse 60% 70% at 50% 0%, #000, transparent 70%); }
      .cta > * { position: relative; }
      .cta h2 { font-size: clamp(30px, 4vw, 48px); color: #fff; }
      .cta p { font-size: 17px; max-width: 460px; margin: 16px auto 28px; color: #aeb6c0; }
      .install { display: inline-flex; align-items: center; gap: 12px; background: #161a20; border: 1px solid #262c34; color: #e7ecf1; border-radius: 10px; padding: 12px 16px; font-family: var(--font-mono); font-size: 15px; margin-bottom: 26px; }
      .install .pp { color: var(--accent-bright); }
      .install button { font-family: var(--font-mono); font-size: 11px; cursor: pointer; background: transparent; color: var(--accent-bright); border: 1px solid #2a323b; border-radius: 6px; padding: 5px 11px; transition: background 0.15s; }
      .install button:hover { background: #1c222a; }
      .cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
      .cta .btn.alt { background: transparent; color: #fff; border-color: #2c333c; }
      .cta .btn.alt:hover { background: #161a20; }

      /* footer */
      footer { padding: 52px 0 40px; border-top: 1px solid var(--line); margin-top: 56px; }
      .foot-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; }
      .foot-grid h6 { font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 14px; color: var(--ink-faint); }
      .foot-grid ul { list-style: none; display: flex; flex-direction: column; gap: 9px; }
      .foot-grid ul a { font-size: 14px; color: var(--ink-soft); }
      .foot-grid ul a:hover { color: var(--accent-deep); }
      .foot-brand p { color: var(--ink-soft); max-width: 280px; margin-top: 12px; font-size: 14px; }
      .foot-bottom { margin-top: 40px; padding-top: 22px; border-top: 1px solid var(--line); display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; font-size: 13px; color: var(--ink-faint); }

      .ribbon { position: fixed; bottom: 16px; left: 16px; z-index: 200; font-family: var(--font-mono); font-size: 11px; color: var(--ink-soft); background: var(--card); padding: 7px 13px; border: 1px solid var(--line-2); border-radius: 8px; box-shadow: 0 6px 20px -10px rgba(20,22,27,0.3); }
      .ribbon:hover { border-color: var(--ink-faint); }

      @media (max-width: 980px) {
        .hero-grid, .prox-grid, .ag-grid, .say-grid, .ctx-grid, .dp-grid { grid-template-columns: 1fr; gap: 40px; }
        .dp-mid { flex-direction: row; min-height: 40px; } .dp-mid .vl { display: none; }
        .modes, .steps { grid-template-columns: 1fr; }
        .arch2 { grid-template-columns: 1fr; gap: 6px; }
        .wire { padding: 8px 0; } .wire .cable { display: none; } .wire .down { display: block; }
        .foot-grid { grid-template-columns: 1fr 1fr; }
        .nav-links { display: none; }
      }
      @media (max-width: 560px) { .nav-cta .gh { display: none; } .rack { gap: 8px; } }
    </style>
  </head>

  <body>
    <a class="ribbon" href="/">← current design</a>

    <nav id="nav">
      <div class="wrap nav-bar">
        <a class="brand" href="/alt"><img src="/logo.svg" alt="" />AppClaw</a>
        <div class="nav-links">
          <a href="#context">Memory</a>
          <a href="#locate">Locators</a>
          <a href="#parallel">Parallel</a>
          <a href="#say">Capabilities</a>
          <a href="#modes">Modes</a>
          <a href="#arch">Architecture</a>
        </div>
        <div class="nav-cta">
          <a class="btn alt sm gh" href={GH} target="_blank" rel="noopener">Star on GitHub</a>
          <a class="btn sm" href={QUICKSTART}>Get Started</a>
        </div>
      </div>
    </nav>

    <div class="wrap">
      <!-- HERO -->
      <section class="hero">
        <div class="hero-grid">
          <div>
            <span class="eyebrow rv in">Open source · Apache 2.0</span>
            <h1 class="rv in d1">Tell <span class="ac">AppClaw</span>. It finds the right element.</h1>
            <p class="hero-sub rv in d2">
              Describe a step in plain English. AppClaw figures out what to tap, type, and swipe on real
              Android &amp; iOS devices — from the <a href="https://www.npmjs.com/package/appclaw" target="_blank" rel="noopener">CLI</a>
              or the <a href={MARKETPLACE} target="_blank" rel="noopener">Cursor &amp; VS Code</a> extension.
            </p>
            <div class="hero-btns rv in d2">
              <a class="btn" href={QUICKSTART}>Get Started</a>
              <a class="btn alt" href={GH} target="_blank" rel="noopener">View on GitHub</a>
            </div>
            <div class="hero-meta rv in d3">
              <span><i></i>Android &amp; iOS</span>
              <span><i></i>Real devices &amp; emulators</span>
              <span><i></i>MCP-native</span>
              <span><i></i>BYO LLM key</span>
            </div>
          </div>

          <!-- phone + locator -->
          <div class="rv in d2">
            <div class="stage">
              <div class="device">
                <div class="screen">
                  <div class="statusbar">
                    <span>9:41</span>
                    <span style="display:flex;align-items:center">
                      <span class="sig"><i></i><i></i><i></i><i></i></span>
                      <span class="batt"></span>
                    </span>
                  </div>
                  <div class="appbar"><span class="app">MyApp</span><svg class="ico" viewBox="0 0 24 24" style="width:18px;height:18px;color:var(--ink-faint)"><path d="M4 6h16M4 12h16M4 18h16" /></svg></div>
                  <div class="scr-body">
                    <h5>Welcome back</h5>
                    <div class="field">name@email.com</div>
                    <div class="field">••••••••</div>
                    <div class="loginbtn">
                      Login
                      <span class="reticle"></span>
                      <span class="rlabel">located · below password</span>
                    </div>
                    <div class="signup">Already have an account? <span class="dlink">Log in</span></div>
                  </div>
                </div>
              </div>
              <div class="stage-cap">resolves the <b>Login</b> button — not the “Log in” text link</div>
            </div>
          </div>
        </div>
      </section>

      <!-- CONTEXT + MEMORY -->
      <section class="block band" id="context" style="padding-top:60px">
        <div class="sec-head rv" style="max-width:700px">
          <span class="eyebrow">Context engineering + memory</span>
          <h2>Context-engineered. <span class="ac">And it remembers.</span></h2>
          <p>AppClaw works from two context sources — the knowledge you hand it, and the experience it earns. Both feed the same context window, so the agent gets the right detail exactly when it needs it.</p>
        </div>
        <div class="ctx-grid">
          <!-- AppGuides -->
          <div class="card soft feat rv d1">
            <div class="fh">
              <span class="fic"><svg class="ico lg" viewBox="0 0 24 24"><rect x="5" y="3" width="14" height="18" rx="2" /><path d="M9 8h6M9 12h6M9 16h3" /></svg></span>
              <div><span class="fk">Context engineering · AppGuides</span><h3>Knowledge you give it</h3></div>
            </div>
            <p>Per-app navigation maps injected into the agent's context — where the compose button lives, which gesture archives, how to reach any setting. No trial-and-error exploration.</p>
            <div class="chips">
              {APPS.map((a) => <span class="pill"><span class="dot"></span>{a}</span>)}
              <span class="pill" style="color:var(--ink-faint)">+ your app</span>
            </div>
            <div class="path">.appclaw/guides/&lt;appId&gt;.md</div>
          </div>
          <!-- Episodic memory -->
          <div class="card soft feat rv d2">
            <div class="fh">
              <span class="fic"><svg class="ico lg" viewBox="0 0 24 24"><path d="M3 12a9 9 0 1 0 9-9 9 9 0 0 0-7.5 4" /><path d="M3 3v4h4" /><path d="M12 8v4l3 2" /></svg></span>
              <div><span class="fk">Episodic memory</span><h3>Knowledge it earns</h3></div>
            </div>
            <p>After every successful run, AppClaw records the winning steps. On the next run it retrieves the most relevant past trajectories — matched by screen and goal — and injects them as a compact hint.</p>
            <div class="mini">
              <div class="r"><span class="tag">run 1</span><span>explores from scratch</span><span>9 steps</span></div>
              <div class="r now"><span class="tag good">run 2</span><span>recalls what worked</span><span class="good">4 steps</span></div>
            </div>
            <div class="path">~/.appclaw/trajectories.json</div>
          </div>
        </div>
      </section>

      <!-- LOCATORS / PROXIMITY -->
      <section class="block" id="locate">
        <div class="prox-grid">
          <div class="rv">
            <span class="eyebrow">Spatial locators</span>
            <h2 style="font-size:clamp(28px,3.6vw,46px);margin-top:16px">Resolves the <span class="ac">right</span> element.</h2>
            <p style="font-size:17px;color:var(--ink-soft);margin-top:14px">
              A “Login” button and a “Log in” text link on the same screen? Skip brittle selectors. Reference the one
              you mean by its position relative to another element — AppClaw resolves it geometrically.
            </p>
            <div class="prox-tags">
              {["below", "above", "left of", "right of", "near", "within"].map((t) => <span class="pill">{t}</span>)}
            </div>
          </div>
          <div class="card soft prox-stage rv d1">
            <div class="uic decoy">Log in &nbsp;·&nbsp; text link</div>
            <div class="uic anchor">Password <span class="lab">anchor</span></div>
            <div class="rel">
              <svg class="ico" viewBox="0 0 24 24" style="width:15px;height:15px"><path d="M12 5v14M19 12l-7 7-7-7" /></svg>
              below
            </div>
            <div class="uic target">Login button &nbsp;·&nbsp; resolved</div>
            <div class="prox-cmd"><span class="g">tap</span> login button <span class="o">below</span> the password field</div>
          </div>
        </div>
      </section>

      <!-- DUAL PERCEPTION -->
      <section class="block band" id="perception">
        <div class="sec-head rv">
          <span class="eyebrow">Dual perception</span>
          <h2>Two ways to see the screen. One reliable <span class="ac" style="font-style:italic">tap</span>.</h2>
          <p>AppClaw reads the structured accessibility tree when it's there — fast, exact, cheap. When it isn't (Canvas, Flutter, games, custom-rendered UI), it falls back to AI vision on the raw screenshot. Same tap, either way.</p>
        </div>
        <div class="card soft rv d1" style="padding:28px">
          <div class="dp-grid">
            <!-- DOM -->
            <div class="dp-col">
              <span class="dp-l">DOM mode · structured</span>
              <h3>Accessibility tree</h3>
              <span class="ds">Parsed straight from page source</span>
              <div class="dp-panel">
                <div class="domx">
                  <div class="file">&lt;/&gt; page_source.xml</div>
                  <div>&lt;<span class="b">FrameLayout</span>&gt;</div>
                  <div>&nbsp;&nbsp;&lt;<span class="b">Button</span> id=<span class="s">"nav_login"</span>/&gt;</div>
                  <div>&nbsp;&nbsp;&lt;<span class="b">EditText</span> hint=<span class="s">"Password"</span>/&gt;</div>
                  <div>&nbsp;&nbsp;<span class="matched">&lt;Button id="btn_submit" ◄ matched/&gt;</span></div>
                  <div>&lt;/<span class="b">FrameLayout</span>&gt;</div>
                </div>
              </div>
              <div class="dp-foot">Exact match. Zero vision tokens.</div>
            </div>

            <!-- combinator -->
            <div class="dp-mid">
              <span class="vl"></span>
              <span class="dp-pill"><svg class="ico" viewBox="0 0 24 24" style="width:13px;height:13px;stroke:#fff"><path d="M12 5v14M5 12h14" /></svg> One tap</span>
              <span class="vl b"></span>
            </div>

            <!-- VISION -->
            <div class="dp-col">
              <span class="dp-l ac">Vision mode · pixels</span>
              <h3>Screenshot + AI</h3>
              <span class="ds">When there's no DOM to read</span>
              <div class="dp-panel">
                <div class="vmock">
                  <div class="vh"><svg class="ico" viewBox="0 0 24 24" style="width:14px;height:14px"><rect x="3" y="4" width="18" height="14" rx="2" /><path d="M3 14l5-4 4 3 3-2 6 5" /></svg> screenshot.png</div>
                  <div class="vb">
                    <div class="vbar" style="width:55%"></div>
                    <div class="vbar" style="height:26px"></div>
                    <div class="vbtn">Login <span class="vret">◎</span></div>
                    <div class="vmatch">match 0.94</div>
                  </div>
                </div>
              </div>
              <div class="dp-foot" style="color:var(--accent-deep)">Locates by pixels when the tree is empty.</div>
            </div>
          </div>
          <div class="dp-strip"><b>DOM</b> first · <b>vision</b> fallback · chosen automatically</div>
        </div>
      </section>

      <!-- PARALLEL -->
      <section class="block" id="parallel">
        <div class="prox-grid">
          <div class="rv">
            <span class="eyebrow">Parallel · one YAML file</span>
            <h2 style="font-size:clamp(28px,3.6vw,46px);margin-top:16px">Run your flow on <span class="ac">every device</span> at once.</h2>
            <p style="font-size:17px;color:var(--ink-soft);margin-top:14px">
              Add one line and AppClaw fans your suite across the whole rack — each device with its own
              screen, step tracking, and pass/fail.
            </p>
            <div class="prox-tags">
              <span class="pill" style="font-family:var(--font-mono);color:var(--accent-deep);background:var(--accent-soft);border-color:#cde9ec">parallel: 4</span>
              <span class="pill">per-device progress</span>
              <span class="pill">live pass/fail</span>
              <span class="pill">suite mode</span>
            </div>
          </div>
          <div class="card soft rack-card rv d1">
            <div class="rack-head">
              <span class="n">{RACK.length} devices</span>
              <span class="lg"><i style="background:var(--accent)"></i> {rackRunning} running</span>
              <span class="lg"><i style="background:#1f9d57"></i> {rackPassed} passed</span>
              <span class="lg"><i style="background:var(--ink-faint);opacity:.5"></i> {rackQueued} queued</span>
            </div>
            <div class="rack">
              {RACK.map((d) => (
                <div class="dev">
                  <span class={`st ${d.s}`}></span>
                  <div class="scr">
                    <div class="ln" style="width:50%"></div>
                    <div class="ln t" style={`width:${d.w}%`}></div>
                    <div class="ln" style="width:72%"></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- PROVIDERS -->
      <section class="block" style="padding:36px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line)">
        <div class="providers rv">
          <span class="lbl">Any LLM provider</span>
          {PROVIDERS.map((p) => <span class="p">{p}</span>)}
        </div>
      </section>

      <!-- SAY IT -->
      <section class="block band" id="say">
        <div class="say-grid">
          <div class="rv">
            <span class="eyebrow">One vocabulary</span>
            <h2 style="font-size:clamp(28px,3.6vw,44px);margin-top:16px">Say it. <span style="color:var(--accent-deep)">It does it.</span></h2>
            <p style="font-size:17px;color:var(--ink-soft);margin-top:14px">
              No selectors, no XPath, no boilerplate. Describe the step the way you'd tell a teammate —
              AppClaw maps it to the right action on the screen.
            </p>
          </div>
          <div class="card soft say-list rv d1">
            {CAPS.map((c) => (
              <div class="say-row">
                <span class="ck"><svg class="ico" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5" /></svg></span>
                <span class="txt">{c.say}</span>
                <span class="act">{c.act}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- MODES -->
      <section class="block" id="modes">
        <div class="sec-head rv">
          <span class="eyebrow">Three modes</span>
          <h2>Every way to automate, <span class="ac">covered.</span></h2>
          <p>An AI agent for messy goals, deterministic YAML for repeatable tests, or a live playground to build flows by hand.</p>
        </div>
        <div class="modes">
          {MODES.map((m, i) => (
            <div class={`card hover mode rv d${i + 1}`}>
              <span class="mode-tag">{m.tag}</span>
              <h3>{m.title}</h3>
              <p>{m.desc}</p>
              <div class="screen-blk">
                {m.lines.map((ln) => (<div><span class="o">{ln[0]}</span> <span>{ln[1]}</span> <span class="m">{ln[2]}</span></div>))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- HOW -->
      <section class="block band" id="how">
        <div class="sec-head rv">
          <span class="eyebrow">How it works</span>
          <h2>Three steps from <span class="ac">intent</span> to execution.</h2>
        </div>
        <div class="steps">
          {STEPS.map((s, i) => (
            <div class={`card hover step rv d${i + 1}`}>
              <div class="n">{s.n}</div>
              <h3>{s.t}</h3>
              <p>{s.d}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- ARCHITECTURE -->
      <section class="block" id="arch">
        <div class="sec-head rv" style="text-align:center;margin:0 auto 40px">
          <span class="eyebrow" style="justify-content:center">Architecture</span>
          <h2>Pure agentic brain. <span class="ac">Zero</span> device logic.</h2>
          <p style="margin-left:auto;margin-right:auto">Every device action is delegated over the open MCP protocol — no drivers, no vendor lock-in.</p>
        </div>
        <div class="arch2 rv d1">
          <div class="card brain">
            <div class="tt">
              <span class="ic"><svg class="ico lg" viewBox="0 0 24 24"><rect x="6" y="6" width="12" height="12" rx="2" /><path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3" /></svg></span>
              <div><h4>AppClaw</h4><span class="sub">the agentic brain</span></div>
            </div>
            <p>Reads the screen, decides the next move, and verifies the result — looping until the goal is met. That's all it does.</p>
            <div class="loop">
              <span class="lp">Perceive</span><span class="ar">→</span><span class="lp">Reason</span><span class="ar">→</span><span class="lp">Act</span><span class="re">↺ repeat</span>
            </div>
          </div>

          <div class="wire">
            <div class="cable"><span class="ln"></span><span class="plug">MCP</span><span class="ln"></span><span class="head">▸</span></div>
            <div class="down">↓</div>
            <div class="sub2">open JSON-RPC · the only interface it speaks</div>
          </div>

          <div class="devland">
            <span class="lbl">Device land</span>
            <div class="note">none of this lives in AppClaw</div>
            <div class="dl-node"><span class="di"><svg class="ico" viewBox="0 0 24 24"><path d="M14 7l-1.5-1.5a3 3 0 00-4 0L3 11l6 6 5.5-5.5a3 3 0 000-4zM14 7l4 4M9 17l-2 4 4-2" /></svg></span><div><h5>appium-mcp</h5><small>32 tools — tap · type · swipe</small></div></div>
            <div class="dl-conn"></div>
            <div class="dl-node"><span class="di"><svg class="ico" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="6" rx="1" /><rect x="3" y="14" width="18" height="6" rx="1" /><path d="M7 7h.01M7 17h.01" /></svg></span><div><h5>Appium</h5><small>automation engine</small></div></div>
            <div class="dl-conn"></div>
            <div class="dl-node"><span class="di"><svg class="ico" viewBox="0 0 24 24"><rect x="7" y="2" width="10" height="20" rx="2" /><path d="M11 18h2" /></svg></span><div><h5>Device</h5><small>Android · iOS · real or emulator</small></div></div>
          </div>
        </div>
      </section>

      <!-- QUOTE -->
      <section class="block band">
        <div class="quote rv">
          <div class="q">“AppClaw automates workflows that used to take <em>hours</em> of scripting — in minutes. Describe it, and it runs.”</div>
          <div class="by">Mobile QA Engineers — teams shipping with AppClaw</div>
        </div>
      </section>

      <!-- CTA -->
      <section class="block">
        <div class="cta rv">
          <h2>Ship mobile automation faster.</h2>
          <p>Open source, extensible, BYO LLM key. Start in under a minute — terminal or IDE.</p>
          <div class="install"><span class="pp">$</span> npx appclaw <button id="copyBtn">Copy</button></div>
          <div class="cta-btns">
            <a class="btn" href={QUICKSTART}>Get Started</a>
            <a class="btn alt" href={GH} target="_blank" rel="noopener">GitHub</a>
          </div>
        </div>
      </section>

      <!-- FOOTER -->
      <footer>
        <div class="foot-grid">
          <div class="foot-brand">
            <a class="brand" href="/alt"><img src="/logo.svg" alt="" />AppClaw</a>
            <p>The mobile automation agent. Tell it what you want in plain English — it resolves the rest.</p>
          </div>
          <div><h6>Product</h6><ul><li><a href="#say">Capabilities</a></li><li><a href="#context">Memory &amp; guides</a></li><li><a href="#modes">Modes</a></li><li><a href="#locate">Locators</a></li><li><a href="#parallel">Parallel</a></li></ul></div>
          <div><h6>Developers</h6><ul><li><a href={QUICKSTART} target="_blank" rel="noopener">Quick Start</a></li><li><a href="https://www.npmjs.com/package/appclaw" target="_blank" rel="noopener">CLI (npm)</a></li><li><a href={MARKETPLACE} target="_blank" rel="noopener">Extension</a></li><li><a href="/usage.html">Usage Guide</a></li></ul></div>
          <div><h6>Community</h6><ul><li><a href={`${GH}/issues`} target="_blank" rel="noopener">Issues</a></li><li><a href={`${GH}/discussions`} target="_blank" rel="noopener">Discussions</a></li><li><a href={`${GH}/blob/main/LICENSE`} target="_blank" rel="noopener">License</a></li></ul></div>
        </div>
        <div class="foot-bottom">
          <span>© 2026 AppClaw. Open source under Apache 2.0.</span>
          <a href={GH} target="_blank" rel="noopener" style="color:var(--ink-soft)">GitHub ↗</a>
        </div>
      </footer>
    </div>

    <script is:inline>
      const nav = document.getElementById("nav");
      if (nav) { const f = () => nav.classList.toggle("scrolled", window.scrollY > 8); window.addEventListener("scroll", f, { passive: true }); f(); }

      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("in"); obs.unobserve(e.target); } });
      }, { threshold: 0.12 });
      document.querySelectorAll(".rv:not(.in)").forEach((el) => obs.observe(el));

      const c = document.getElementById("copyBtn");
      if (c) c.addEventListener("click", () => { navigator.clipboard.writeText("npx appclaw").then(() => { c.textContent = "Copied"; setTimeout(() => (c.textContent = "Copy"), 1800); }); });

      document.querySelectorAll('a[href^="#"]').forEach((a) => {
        a.addEventListener("click", function (e) {
          const id = this.getAttribute("href");
          if (id && id.length > 1) { const t = document.querySelector(id); if (t) { e.preventDefault(); t.scrollIntoView({ behavior: "smooth" }); } }
        });
      });
    </script>
  </body>
</html>
