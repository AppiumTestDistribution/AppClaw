---
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "../components/ThemeToggle.tsx";
import MobileMenu from "../components/MobileMenu.tsx";

const NAV_LINKS = [
  { label: "Parallel", href: "#parallel" },
  { label: "Features", href: "#features" },
  { label: "AppGuide", href: "#appguide" },
  { label: "How It Works", href: "#how-it-works" },
  { label: "Architecture", href: "#architecture" },
  { label: "Usage Guide", href: "/usage.html" },
];

const PROVIDERS = ["Anthropic", "OpenAI", "Google", "Groq", "Ollama"];

const MODES = [
  {
    badge: "Agent Mode",
    tone: "accent",
    title: "From prompt to completed action",
    desc: "Describe a goal in plain English. AppClaw reads the screen, reasons, and executes until done.",
    file: "Agent Mode",
  },
  {
    badge: "YAML Flows",
    tone: "support",
    title: "Deterministic steps, zero LLM cost",
    desc: "Write plain-English YAML. No AI needed at runtime — fast, repeatable, with vision fallback.",
    file: "login-flow.yaml",
  },
  {
    badge: "Playground",
    tone: "green",
    title: "Build flows interactively",
    desc: "Live REPL on a real device. Type commands, watch them execute, export to YAML.",
    file: "Playground",
  },
];

const PROXIMITY = ["below", "above", "left of", "right of", "near", "within"];

const APPGUIDE_APPS = [
  { icon: "✉️", name: "Gmail" },
  { icon: "▶️", name: "YouTube" },
  { icon: "💬", name: "WhatsApp" },
  { icon: "🌐", name: "Chrome" },
  { icon: "⚙️", name: "Settings" },
];

const STEPS = [
  {
    number: "01",
    title: "Describe your goal",
    desc: "Write what you want in plain English. AppClaw accepts goals as prompts, YAML files, or playground commands.",
  },
  {
    number: "02",
    title: "AI perceives and reasons",
    desc: "AppClaw captures the screen, sends it to your LLM, and receives a structured plan. Handles popups, adapts to state.",
  },
  {
    number: "03",
    title: "Execute and verify",
    desc: "Actions run via Appium through MCP. AppClaw verifies after every step and continues until the goal is achieved.",
  },
];

const ARCH = [
  { icon: "🧠", tone: "accent", name: "AppClaw", desc: "AI Agent — Perceive → Reason → Act" },
  { icon: "⚡", tone: "support", name: "MCP Protocol", desc: "JSON-RPC — open standard" },
  { icon: "🔧", tone: "support", name: "appium-mcp", desc: "32 tools — tap, type, swipe, assert…" },
  { icon: "📱", tone: "green", name: "Appium", desc: "Device automation layer" },
  { icon: "📲", tone: "muted", name: "Device", desc: "Android · iOS — real or emulator" },
];

const STATS = [
  { num: "3", label: "Modes" },
  { num: "10", label: "App Guides" },
  { num: "32", label: "MCP Tools" },
  { num: "5", label: "Providers" },
  { num: "2", label: "Platforms" },
];

const GH = "https://github.com/AppiumTestDistribution/appclaw";
const QUICKSTART = `${GH}#quick-start`;
const MARKETPLACE =
  "https://marketplace.visualstudio.com/items?itemName=AppClaw.appclaw";

const badgeTone: Record<string, string> = {
  accent: "text-accent bg-accent/10 border-accent/25",
  support: "text-support bg-support/10 border-support/25",
  green: "text-emerald-400 bg-emerald-400/10 border-emerald-400/25",
};

const iconTone: Record<string, string> = {
  accent: "bg-accent/15 text-accent",
  support: "bg-support/15 text-support",
  green: "bg-emerald-400/15 text-emerald-400",
  muted: "bg-foreground/8 text-muted-foreground",
};
---

<Layout>
  <!-- ─── Navbar ─── -->
  <header
    id="nav-header"
    class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-5 md:px-10 lg:px-16 h-[60px] font-body bg-background/75 backdrop-blur-xl border-b border-transparent transition-colors"
  >
    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <img src="/logo.svg" alt="AppClaw" class="h-[26px] w-[26px]" />
      <span class="font-display text-[19px] font-bold tracking-tight text-foreground">AppClaw</span>
    </a>

    <nav class="hidden md:flex items-center gap-1 flex-1 ml-10">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-muted-foreground hover:text-foreground hover:bg-secondary/70 px-3 py-1.5 rounded-md transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2.5">
      <div class="hidden md:block">
        <ThemeToggle client:load />
      </div>
      <a
        href={GH}
        target="_blank"
        rel="noopener"
        class="hidden sm:inline-flex items-center gap-1.5 text-[13px] font-medium text-muted-foreground border border-border hover:border-foreground/25 hover:text-foreground hover:bg-secondary/60 px-3.5 py-1.5 rounded-lg transition-colors"
      >
        <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
        </svg>
        Star
      </a>
      <a
        href={QUICKSTART}
        class="hidden sm:inline-flex items-center justify-center rounded-full bg-primary text-primary-foreground px-5 py-2 text-sm font-medium hover:bg-primary/90 transition-colors"
      >
        Get Started
      </a>
      <MobileMenu client:load />
    </div>
  </header>

  <!-- ─── Hero ─── -->
  <section class="relative pt-32 md:pt-40 pb-16 md:pb-24 overflow-hidden">
    <div class="bg-grid bg-grid-fade absolute inset-0 -z-10"></div>
    <div class="absolute top-[-12%] left-1/2 -translate-x-1/2 w-[820px] h-[520px] rounded-full bg-accent/10 blur-[120px] -z-10 pointer-events-none"></div>

    <div class="max-w-6xl mx-auto px-6 md:px-10 grid grid-cols-1 lg:grid-cols-[1.05fr_0.95fr] gap-12 lg:gap-16 items-center">
      <!-- Copy -->
      <div>
        <div class="reveal inline-flex items-center gap-2 rounded-full border border-accent/25 bg-accent/8 px-3.5 py-1.5 text-[11px] font-code uppercase tracking-[0.14em] text-accent mb-7">
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full rounded-full bg-accent opacity-60 animate-ping"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-accent"></span>
          </span>
          Open Source · Apache 2.0
        </div>

        <h1 class="reveal reveal-delay-1 font-display text-5xl md:text-6xl lg:text-7xl leading-[0.98] tracking-tight text-foreground">
          The intelligent<br />agent for <em class="text-accent">mobile</em>.
        </h1>

        <p class="reveal reveal-delay-2 mt-6 text-base md:text-lg text-muted-foreground max-w-xl leading-relaxed">
          Describe what you want in plain English. AppClaw figures out what to tap, type, and swipe — on
          real Android and iOS devices. Run it from the <strong class="text-foreground font-semibold">CLI</strong>
          or install the extension in <strong class="text-foreground font-semibold">Cursor</strong>,
          <strong class="text-foreground font-semibold">VS Code</strong>, and compatible editors from the
          <a href={MARKETPLACE} target="_blank" rel="noopener" class="text-accent underline decoration-accent/30 underline-offset-4 hover:decoration-accent transition-colors">Marketplace</a>.
        </p>

        <div class="reveal reveal-delay-3 mt-8 flex flex-wrap items-center gap-3">
          <a href={QUICKSTART} class="inline-flex items-center gap-2 rounded-full bg-primary text-primary-foreground px-7 py-3 text-sm font-medium hover:bg-primary/90 transition-colors shadow-[0_8px_30px_-8px_hsl(var(--primary)/0.7)]">
            Get Started
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
          </a>
          <a href={GH} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border border-border px-7 py-3 text-sm font-medium text-foreground hover:bg-secondary/60 transition-colors">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" /></svg>
            View on GitHub
          </a>
        </div>
      </div>

      <!-- Visual: phone + YAML card -->
      <div class="reveal reveal-delay-2 relative flex items-start justify-center gap-4 sm:gap-5">
        <div class="absolute inset-0 -m-10 bg-accent/8 blur-[80px] rounded-full -z-10"></div>
        <!-- Phone -->
        <div class="relative w-[200px] sm:w-[220px] shrink-0 rounded-[40px] border-2 border-white/12 bg-[#0a0a0a] p-2.5 shadow-[0_0_0_1px_rgba(255,255,255,0.05),0_40px_80px_rgba(0,0,0,0.55),0_0_60px_hsl(var(--accent)/0.12)]">
          <div class="rounded-[30px] overflow-hidden bg-black">
            <img src="/demo.gif" alt="AppClaw controlling a real Android device" loading="eager" class="block w-full h-auto" />
          </div>
        </div>
        <!-- YAML card -->
        <div class="relative top-10 rounded-xl border border-border bg-[#0f141b] overflow-hidden shadow-[0_16px_48px_rgba(0,0,0,0.5)] min-w-[200px]">
          <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent to-transparent opacity-60"></div>
          <div class="flex items-center gap-1.5 px-3.5 py-2.5 border-b border-white/5">
            <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
            <span class="ml-2 text-[11px] font-code text-[#7d8590]">whatsapp.yaml</span>
          </div>
          <pre class="px-4 py-3.5 font-code text-[12.5px] leading-[1.85] text-[#c9d1d9] overflow-x-auto"><code><span class="text-[#79c0ff]">name:</span> <span class="text-accent">whatsapp_hello</span>
<span class="text-[#79c0ff]">platform:</span> <span class="text-accent">android</span>

<span class="text-[#79c0ff]">steps:</span>
  <span class="text-[#7d8590]">-</span> open WhatsApp
  <span class="text-[#7d8590]">-</span> tap search icon
  <span class="text-[#7d8590]">-</span> type "Mom"
  <span class="text-[#7d8590]">-</span> tap Mom conversation
  <span class="text-[#7d8590]">-</span> type "Hello!"
  <span class="text-[#7d8590]">-</span> tap send button

<span class="text-[#79c0ff]">done:</span> <span class="text-emerald-400">"Message sent ✓"</span></code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Providers ─── -->
  <section class="w-full px-6 md:px-12 lg:px-20 py-12 border-t border-border">
    <div class="max-w-5xl mx-auto reveal">
      <p class="text-center text-[10.5px] uppercase tracking-[0.2em] text-muted-foreground font-code mb-7">
        Works with any LLM provider
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 md:gap-x-12">
        {PROVIDERS.map((p) => (
          <span class="font-display text-base md:text-lg font-bold tracking-tight text-muted-foreground hover:text-foreground transition-colors">{p}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Run surface ─── -->
  <section class="w-full px-6 md:px-12 lg:px-20 py-10 border-b border-border">
    <div class="max-w-3xl mx-auto reveal text-center">
      <p class="text-[10.5px] uppercase tracking-[0.2em] text-accent font-code mb-4">Where you run it</p>
      <p class="text-base md:text-[17px] text-muted-foreground leading-relaxed">
        <a href="https://www.npmjs.com/package/appclaw" target="_blank" rel="noopener" class="text-foreground font-medium hover:text-accent transition-colors">CLI</a>
        (<code class="font-code text-[0.85em] text-accent bg-accent/8 rounded px-1.5 py-0.5">npx appclaw</code>) for terminals and CI,
        <a href="https://www.npmjs.com/package/appclaw-agent" target="_blank" rel="noopener" class="text-foreground font-medium hover:text-accent transition-colors">Agent CLI</a>
        (<code class="font-code text-[0.85em] text-accent bg-accent/8 rounded px-1.5 py-0.5">npm i -g appclaw-agent</code>) for AI coding agents like Claude Code and Gemini CLI, or the
        <a href={MARKETPLACE} target="_blank" rel="noopener" class="text-foreground font-medium hover:text-accent transition-colors">Visual Studio Marketplace</a>
        extension for <strong class="text-foreground font-semibold">Cursor</strong>, <strong class="text-foreground font-semibold">VS Code</strong>, and forks that load the same extension catalog.
      </p>
    </div>
  </section>

  <!-- ─── Parallel Execution ─── -->
  <section id="parallel" class="relative w-full px-6 md:px-12 lg:px-20 py-24 scroll-mt-20 overflow-hidden">
    <div class="bg-grid bg-grid-fade absolute inset-0 -z-10 opacity-60"></div>
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-12 lg:gap-16 items-center">
      <div class="reveal rounded-2xl overflow-hidden border border-accent/20 shadow-[0_0_0_1px_hsl(var(--accent)/0.08),0_40px_100px_rgba(0,0,0,0.5)]">
        <img src="/parallel-demo.gif" alt="AppClaw running tests across 4 devices in parallel" loading="lazy" class="block w-full h-auto" />
      </div>
      <div class="reveal reveal-delay-1 flex flex-col gap-7">
        <div>
          <span class="inline-flex items-center gap-2.5 text-[10.5px] uppercase tracking-[0.18em] text-accent font-code font-medium before:block before:w-5 before:h-px before:bg-accent">Parallel Execution</span>
          <h2 class="mt-4 font-display text-4xl md:text-5xl leading-[0.98] tracking-tight text-foreground">Four devices.<br />One <em class="text-accent">YAML</em> file.</h2>
          <p class="mt-4 text-base md:text-lg text-muted-foreground leading-relaxed">
            Add <code class="font-code text-[0.85em] text-accent bg-accent/8 rounded px-1.5 py-0.5">parallel: 4</code> and AppClaw runs your flow across every device at once — each with its own screen, step tracking, and pass/fail result.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          {["4 devices at once", "Per-device progress", "Suite mode", "Zero config"].map((p) => (
            <span class="inline-flex items-center gap-2 text-[13px] text-muted-foreground border border-border bg-secondary/40 rounded-full px-3.5 py-1.5">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>{p}
            </span>
          ))}
        </div>
        <div class="rounded-xl border border-border bg-[#0f141b] overflow-hidden">
          <div class="flex items-center gap-1.5 px-3.5 py-2.5 border-b border-white/5">
            <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
            <span class="ml-2 text-[11px] font-code text-[#7d8590]">youtube-suite.yaml</span>
          </div>
          <pre class="px-4 py-3.5 font-code text-[13px] leading-[1.9] text-[#c9d1d9] overflow-x-auto"><code><span class="text-[#79c0ff]">name:</span> <span class="text-accent">youtube_suite</span>
<span class="text-[#79c0ff]">platform:</span> <span class="text-accent">android</span>
<span class="text-support">parallel:</span> <span class="text-support">4</span>
<span class="text-[#79c0ff]">flows:</span>
  <span class="text-[#7d8590]">-</span> youtube.yaml
  <span class="text-[#7d8590]">-</span> login.yaml
  <span class="text-[#7d8590]">-</span> checkout.yaml</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Three Modes ─── -->
  <section id="features" class="w-full px-6 md:px-12 lg:px-20 py-24 border-t border-border scroll-mt-20">
    <div class="max-w-6xl mx-auto">
      <div class="reveal max-w-2xl">
        <span class="inline-flex items-center gap-2.5 text-[10.5px] uppercase tracking-[0.18em] text-accent font-code font-medium before:block before:w-5 before:h-px before:bg-accent">Three modes</span>
        <h2 class="mt-4 font-display text-4xl md:text-5xl leading-[0.98] tracking-tight text-foreground">Every way to automate, <em class="text-accent">covered</em>.</h2>
        <p class="mt-4 text-base md:text-lg text-muted-foreground leading-relaxed">AI agent for complex goals, YAML flows for repeatable tests, or an interactive playground to build live.</p>
      </div>

      <div class="reveal reveal-delay-1 mt-12 grid grid-cols-1 md:grid-cols-3 gap-5">
        {MODES.map((m) => (
          <div class="group rounded-2xl border border-border bg-secondary/20 hover:bg-secondary/40 hover:border-accent/30 transition-colors p-6 flex flex-col">
            <span class={`self-start inline-flex items-center font-code text-[10px] font-semibold uppercase tracking-[0.08em] px-2.5 py-1 rounded-md border ${badgeTone[m.tone]}`}>{m.badge}</span>
            <h3 class="mt-5 font-display text-xl font-bold tracking-tight text-foreground leading-snug">{m.title}</h3>
            <p class="mt-2 text-[15px] text-muted-foreground leading-relaxed">{m.desc}</p>
            <div class="mt-5 rounded-lg border border-white/5 bg-[#0f141b] overflow-hidden">
              <div class="flex items-center gap-1.5 px-3 py-2 border-b border-white/5">
                <span class="h-2 w-2 rounded-full bg-[#ff5f57]"></span>
                <span class="h-2 w-2 rounded-full bg-[#febc2e]"></span>
                <span class="h-2 w-2 rounded-full bg-[#28c840]"></span>
                <span class="ml-1.5 text-[10px] font-code text-[#7d8590]">{m.file}</span>
              </div>
              <pre class="px-3.5 py-3 font-code text-[12px] leading-[1.8] text-[#8b949e] overflow-x-auto">{m.badge === "Agent Mode" ? (
                <code><span class="text-accent">$</span> <span class="text-[#c9d1d9]">appclaw</span> <span class="text-emerald-400">"Turn on WiFi"</span>

<span class="text-accent">1/3</span> <span class="text-[#c9d1d9]">launch</span> → Settings
<span class="text-accent">2/3</span> <span class="text-[#c9d1d9]">tap</span> → Network &amp; internet
<span class="text-accent">3/3</span> <span class="text-[#c9d1d9]">tap</span> → Wi-Fi toggle

<span class="text-emerald-400">✓ Done</span> — 3 steps, 8s, $0.002</code>
              ) : m.badge === "YAML Flows" ? (
                <code><span class="text-support">steps:</span>
  - <span class="text-[#c9d1d9]">open YouTube app</span>
  - <span class="text-[#c9d1d9]">click on search icon</span>
  - <span class="text-[#c9d1d9]">type "Appium 3.0"</span>
  - <span class="text-[#c9d1d9]">scroll until "TestMu" visible</span>
  - <span class="text-[#c9d1d9]">verify TestMu AI is visible</span>
<span class="text-emerald-400">done:</span> <span class="text-accent">"Search results visible"</span></code>
              ) : (
                <code><span class="text-emerald-400">pg&gt;</span> <span class="text-[#c9d1d9]">tap on Settings</span>
<span class="text-emerald-400">✓</span> Tapped "Settings"
<span class="text-emerald-400">pg&gt;</span> <span class="text-[#c9d1d9]">scroll to General</span>
<span class="text-emerald-400">✓</span> "General" visible
<span class="text-emerald-400">pg&gt;</span> <span class="text-[#c9d1d9]">verify About is visible</span>
<span class="text-emerald-400">✓</span> Verified
<span class="text-emerald-400">pg&gt;</span> <span class="text-[#c9d1d9]">/export flow.yaml</span>
<span class="text-emerald-400">✓</span> Saved (3 steps)</code>
              )}</pre>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── Perception: DOM + Vision ─── -->
  <section id="perception" class="w-full px-6 md:px-12 lg:px-20 py-24 border-t border-border scroll-mt-20">
    <div class="max-w-6xl mx-auto">
      <div class="reveal max-w-2xl">
        <span class="inline-flex items-center gap-2.5 text-[10.5px] uppercase tracking-[0.18em] text-accent font-code font-medium before:block before:w-5 before:h-px before:bg-accent">Dual Perception</span>
        <h2 class="mt-4 font-display text-4xl md:text-5xl leading-[0.98] tracking-tight text-foreground">Two ways to see the screen. One reliable <em class="text-accent">tap</em>.</h2>
        <p class="mt-4 text-base md:text-lg text-muted-foreground leading-relaxed">
          AppClaw reads the structured accessibility tree when it's there — fast, exact, cheap. When it isn't (Canvas, Flutter, games, custom-rendered UI), it falls back to AI vision on the raw screenshot. Same tap, either way.
        </p>
