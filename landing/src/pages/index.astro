    <script is:inline>
      const nav = document.getElementById("nav");
      if (nav) { const f = () => nav.classList.toggle("scrolled", window.scrollY > 8); window.addEventListener("scroll", f, { passive: true }); f(); }

      // theme switch, light default, persisted under "theme"
      const root = document.documentElement;
      const tg = document.getElementById("themeToggle");
      const sync = () => { if (tg) tg.setAttribute("aria-checked", root.classList.contains("dark") ? "true" : "false"); };
      sync();
      if (tg) tg.addEventListener("click", () => {
        root.classList.add("theme-anim");
        const dark = root.classList.toggle("dark");
        try { localStorage.setItem("theme", dark ? "dark" : "light"); } catch (e) {}
        sync();
        window.setTimeout(() => root.classList.remove("theme-anim"), 280);
      });

      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("in"); obs.unobserve(e.target); } });
      }, { threshold: 0.12 });
      document.querySelectorAll(".rv:not(.in)").forEach((el) => obs.observe(el));

      const c = document.getElementById("copyBtn");
      if (c) c.addEventListener("click", () => { navigator.clipboard.writeText("npx appclaw").then(() => { c.textContent = "Copied"; setTimeout(() => (c.textContent = "Copy"), 1800); }); });

      document.querySelectorAll('a[href^="#"]').forEach((a) => {
        a.addEventListener("click", function (e) {
          const id = this.getAttribute("href");
          if (id && id.length > 1) { const t = document.querySelector(id); if (t) { e.preventDefault(); t.scrollIntoView({ behavior: "smooth" }); } }
        });
      });
    </script>
